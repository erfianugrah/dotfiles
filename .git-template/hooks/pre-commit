#!/bin/bash

# Pre-commit hook: prevent committing unencrypted secrets.
#
# Detects SOPS encryption (age, KMS, PGP) and raw age-encrypted files.
#
# Checks:
#   1. .env, .tfvars, .tfstate — MUST be encrypted
#   2. .yaml, .yml, .json — only flagged if they contain secret-like values
#
# .sops.yaml integration:
#   Files matching path_regex creation_rules are checked for SOPS encryption.
#
# Exceptions:
#   .allow-unencrypted         — skip ALL checks for this repo
#   .allow-unencrypted-paths   — one glob pattern per line; matching files skip

set -euo pipefail

# ── Exceptions ───────────────────────────────────────────────────────────────

if [ -f ".allow-unencrypted" ]; then
    exit 0
fi

ALLOW_PATHS=()
if [ -f ".allow-unencrypted-paths" ]; then
    while IFS= read -r line; do
        line="${line%%#*}"
        line="$(echo "$line" | xargs)" 2>/dev/null || true
        [ -n "$line" ] && ALLOW_PATHS+=("$line")
    done < .allow-unencrypted-paths
fi

is_path_allowed() {
    for pattern in "${ALLOW_PATHS[@]+"${ALLOW_PATHS[@]}"}"; do
        # shellcheck disable=SC2254
        case "$1" in $pattern) return 0 ;; esac
    done
    return 1
}

# ── Encryption detection ─────────────────────────────────────────────────────

is_encrypted() {
    local file="$1"
    # SOPS encrypted values (all formats)
    grep -q "ENC\[AES256_GCM," "$file" 2>/dev/null && return 0
    # SOPS dotenv metadata (sops_age__*, sops_mac, etc.)
    grep -q "^sops_" "$file" 2>/dev/null && return 0
    # SOPS YAML/JSON metadata
    grep -q "^sops:" "$file" 2>/dev/null && return 0
    grep -q '"sops"' "$file" 2>/dev/null && return 0
    # Raw age encryption
    head -1 "$file" 2>/dev/null | grep -q "^-----BEGIN AGE ENCRYPTED FILE-----$" && return 0
    return 1
}

# ── Secret content detection ─────────────────────────────────────────────────

SECRET_PATTERNS='(password|secret|token|api_key|private_key|credentials?|client_secret|encryption_key|access_key)["\x27]?\s*[:=]\s*["\x27]?[a-zA-Z0-9+/=_\-]{8,}'

has_secrets() {
    grep -iEq "$SECRET_PATTERNS" "$1" 2>/dev/null || return 1
    # Exclude env var references like ${VAR}, {$VAR}, $VAR
    grep -iE "$SECRET_PATTERNS" "$1" 2>/dev/null \
        | grep -vE '[\$]\{|{\$|\$[A-Z_]+' \
        | grep -iEq "$SECRET_PATTERNS" 2>/dev/null
}

# ── .sops.yaml integration ──────────────────────────────────────────────────

SOPS_RULES=()
if [ -f ".sops.yaml" ]; then
    while IFS= read -r regex; do
        [ -n "$regex" ] && SOPS_RULES+=("$regex")
    done < <(grep 'path_regex:' .sops.yaml 2>/dev/null | sed 's/.*path_regex:\s*//' | tr -d "'\"")
fi

matches_sops_rules() {
    for rule in "${SOPS_RULES[@]+"${SOPS_RULES[@]}"}"; do
        echo "$1" | grep -qE "$rule" 2>/dev/null && return 0
    done
    return 1
}

# ── Main ─────────────────────────────────────────────────────────────────────

BLOCKED=""

while IFS= read -r file; do
    [ -f "$file" ] || continue
    is_path_allowed "$file" && continue

    # .env, .tfvars, .tfstate — must be encrypted
    if echo "$file" | grep -qE '\.(env|tfvars)$' || echo "$file" | grep -qE '\.tfstate(\.backup)?$'; then
        is_encrypted "$file" || BLOCKED="$BLOCKED  $file\n"
        continue
    fi

    # .sops.yaml creation_rules — must be SOPS-encrypted
    if matches_sops_rules "$file"; then
        is_encrypted "$file" || BLOCKED="$BLOCKED  $file (matched .sops.yaml rule)\n"
        continue
    fi

    # .yaml, .yml, .json — only if they contain secrets
    if echo "$file" | grep -qE '\.(yaml|yml|json)$'; then
        if has_secrets "$file" && ! is_encrypted "$file"; then
            BLOCKED="$BLOCKED  $file\n"
        fi
    fi
done < <(git diff --cached --name-only 2>/dev/null || true)

# ── Output ───────────────────────────────────────────────────────────────────

RC=0

if [ -n "$BLOCKED" ]; then
    echo "🚫 Unencrypted sensitive files:"
    echo -e "$BLOCKED"
    echo "Encrypt with:  sops --encrypt --in-place <file>"
    echo ""
    RC=1
fi

if [ $RC -ne 0 ]; then
    echo "Skip repo:   touch .allow-unencrypted"
    echo "Skip paths:  add globs to .allow-unencrypted-paths"
    echo ""
fi

exit $RC

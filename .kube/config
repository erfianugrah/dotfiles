apiVersion: v1
clusters:
- cluster:
    server: https://kubectl.erfianugrah.com
  name: default
contexts:
- context:
    cluster: default
    user: default
  name: default
- context:
    cluster: default
    user: oidc
  name: oidc
current-context: default
kind: Config
preferences: {}
users:
- name: default
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      args:
      - oidc-login
      - get-token
      - --oidc-issuer-url=https://erfianugrah.cloudflareaccess.com/cdn-cgi/access/sso/oidc/2f492d4ee1ca7284f60907378f660bca0ec94f2b7018c4025c91e59daf8fb791
      - --oidc-client-id=2f492d4ee1ca7284f60907378f660bca0ec94f2b7018c4025c91e59daf8fb791
      - --oidc-pkce-method=S256
      - --oidc-extra-scope=openid
      - --oidc-extra-scope=groups
      - --oidc-extra-scope=profile
      - --oidc-extra-scope=email
      - --oidc-extra-scope=offline_access
      - --grant-type=auto
      - --force-refresh=false 
      command: kubectl
      env: null
      interactiveMode: IfAvailable
      provideClusterInfo: false

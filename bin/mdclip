#!/usr/bin/env bash
# mdclip - put a Markdown draft on the OS clipboard in the format a given paste
# target actually accepts, so pasting preserves formatting instead of showing
# raw markdown.
#
# Modes:
#   (default)      Markdown -> HTML, clipboard as rich text. For Gmail / Outlook
#                  / Google Docs / any WYSIWYG box: bold, bullets, headings,
#                  links, tables, monospace all survive paste.
#   chat flavours  Markdown -> that app's plain-text markup, clipboard as plain
#                  text ONLY. These apps ignore pasted HTML and read the plain
#                  slot, applying their own inline markup on send:
#     --slack      **bold**->*bold*, italic->_i_, [t](u)-><u|t>, #H->*H*,
#                  bullets->bullet dot, strike ~~x~~->~x~.
#     --discord    near-identity GFM: keeps **bold**, *italic*, `code`, ```fences
#                  (with lang highlight), # headers, - bullets, ~~strike~~;
#                  [t](u)->"t (u)" (Discord masked links are embed-only).
#     --telegram   **bold** kept, italic->__i__, [t](u) kept, #H->**H**, `code`
#                  and ```fences``` kept, strike ~~x~~ kept.
#     --whatsapp   **bold**->*bold*, italic->_i_, strike ~~x~~->~x~, #H->*H*,
#                  [t](u)->"t (u)", `code`/```fences``` and - bullets kept.
#   All chat flavours drop GFM table delimiter rows and pass code fences verbatim.
#
# Cross-OS. The Markdown -> HTML render is portable (Quarto's bundled pandoc);
# only the clipboard-set step is platform-specific:
#   WSL      powershell.exe + .NET CF_HTML DataObject (HTML + plain fallback)
#   macOS    textutil (HTML -> RTF) | pbcopy  (rich) / pbcopy (plain)
#   Wayland  wl-copy --type text/html          (rich) / wl-copy (plain)
#   X11      xclip -t text/html                (rich) / xclip (plain)
#
# Usage:
#   mdclip reply.md              # rich text (Gmail/Docs/WYSIWYG)
#   mdclip < reply.md            # from stdin
#   mdclip --slack     reply.md  # Slack mrkdwn, plain text
#   mdclip --discord   reply.md  # Discord markdown
#   mdclip --telegram  reply.md  # Telegram markdown
#   mdclip --whatsapp  reply.md  # WhatsApp markup
#   mdclip -s < reply.md         # short flags: -s -d -t -w
#
# Notes:
#   - Input is treated as GitHub-Flavoured Markdown (gfm). In every chat flavour
#     a single *word* is markdown ITALIC; use **word** for bold. (Don't feed
#     already-app-formatted text back through a chat flavour.)
#   - Rich mode: code blocks arrive as monospace; Gmail will not syntax-
#     highlight them. For highlighted/long code, link a gist or paste a shot.
#   - Only WSL sets BOTH a rich flavour and a plain-text fallback in one shot.
#     On macOS/Wayland/X11 the single-flavour clipboard tools set the rich
#     flavour only; every rich editor reads it, terminal paste won't.
#   - Keep the SOURCE unwrapped (one line per paragraph/bullet) so hard
#     line-breaks do not leak into the output. See the paste-formatting skill.
set -euo pipefail

# ---------------------------------------------------------------------------
# Platform detection. WSL MUST be checked before Wayland/X11: WSLg sets
# WAYLAND_DISPLAY and DISPLAY, but the real clipboard is the Windows one.
# ---------------------------------------------------------------------------
detect_platform() {
  case "$(uname -s)" in
    Darwin) echo macos; return ;;
    Linux)
      if grep -qi microsoft /proc/version 2>/dev/null; then echo wsl; return; fi
      if [ -n "${WAYLAND_DISPLAY:-}" ]; then echo wayland; return; fi
      if [ -n "${DISPLAY:-}" ]; then echo x11; return; fi
      echo headless; return ;;
    *) echo unknown; return ;;
  esac
}
platform="$(detect_platform)"

need() { command -v "$1" >/dev/null 2>&1 || { echo "mdclip: $1 not found ($2)" >&2; exit 1; }; }

# ---------------------------------------------------------------------------
# Clipboard backends. Each takes file paths so no shell-quoting hell.
#   set_clip_rich  <html-file> <text-file>
#   set_clip_plain <text-file>
# ---------------------------------------------------------------------------
set_clip_rich() {
  local htmlfile="$1" textfile="$2"
  case "$platform" in
    wsl)
      need powershell.exe "this tool needs powershell.exe on WSL"
      local tmpps; tmpps="$(mktemp --suffix=.ps1)"
      # shellcheck disable=SC2064
      trap "rm -f '$tmpps'" RETURN
      cat > "$tmpps" <<'PSEOF'
param([string]$HtmlPath, [string]$TextPath)
Add-Type -AssemblyName System.Windows.Forms
$enc  = New-Object System.Text.UTF8Encoding($false)
$frag = [System.IO.File]::ReadAllText($HtmlPath, $enc)
$text = [System.IO.File]::ReadAllText($TextPath, $enc)
$pre  = "<html><body><!--StartFragment-->"
$post = "<!--EndFragment--></body></html>"
# Fixed 10-digit fields => header byte length is constant regardless of values.
$hfmt = "Version:0.9`r`nStartHTML:{0:0000000000}`r`nEndHTML:{1:0000000000}`r`nStartFragment:{2:0000000000}`r`nEndFragment:{3:0000000000}`r`n"
$hlen = $enc.GetByteCount(($hfmt -f 0,0,0,0))
$sh   = $hlen
$sf   = $sh + $enc.GetByteCount($pre)
$ef   = $sf + $enc.GetByteCount($frag)
$eh   = $ef + $enc.GetByteCount($post)
$cf   = ($hfmt -f $sh,$eh,$sf,$ef) + $pre + $frag + $post
$do = New-Object System.Windows.Forms.DataObject
$do.SetData([System.Windows.Forms.DataFormats]::Html, $false, $cf)
$do.SetData([System.Windows.Forms.DataFormats]::UnicodeText, $false, $text)
[System.Windows.Forms.Clipboard]::SetDataObject($do, $true)
PSEOF
      powershell.exe -NoProfile -STA -ExecutionPolicy Bypass -File "$(wslpath -w "$tmpps")" "$(wslpath -w "$htmlfile")" "$(wslpath -w "$textfile")" >/dev/null
      ;;
    macos)
      need textutil "macOS rich clipboard needs textutil (built in)"
      need pbcopy   "macOS clipboard needs pbcopy (built in)"
      textutil -stdin -stdout -format html -convert rtf < "$htmlfile" | pbcopy
      ;;
    wayland)
      need wl-copy "Wayland clipboard needs wl-clipboard (wl-copy)"
      wl-copy --type text/html < "$htmlfile"
      ;;
    x11)
      need xclip "X11 clipboard needs xclip"
      xclip -selection clipboard -t text/html < "$htmlfile"
      ;;
    *)
      echo "mdclip: no clipboard backend for platform '$platform'" >&2; exit 1 ;;
  esac
}

set_clip_plain() {
  local textfile="$1"
  case "$platform" in
    wsl)
      need powershell.exe "this tool needs powershell.exe on WSL"
      local tmpps; tmpps="$(mktemp --suffix=.ps1)"
      # shellcheck disable=SC2064
      trap "rm -f '$tmpps'" RETURN
      cat > "$tmpps" <<'PSEOF'
param([string]$TextPath)
Add-Type -AssemblyName System.Windows.Forms
$enc  = New-Object System.Text.UTF8Encoding($false)
$text = [System.IO.File]::ReadAllText($TextPath, $enc)
$do = New-Object System.Windows.Forms.DataObject
$do.SetData([System.Windows.Forms.DataFormats]::UnicodeText, $false, $text)
[System.Windows.Forms.Clipboard]::SetDataObject($do, $true)
PSEOF
      powershell.exe -NoProfile -STA -ExecutionPolicy Bypass -File "$(wslpath -w "$tmpps")" "$(wslpath -w "$textfile")" >/dev/null
      ;;
    macos)
      need pbcopy "macOS clipboard needs pbcopy (built in)"
      pbcopy < "$textfile" ;;
    wayland)
      need wl-copy "Wayland clipboard needs wl-clipboard (wl-copy)"
      wl-copy < "$textfile" ;;
    x11)
      need xclip "X11 clipboard needs xclip"
      xclip -selection clipboard < "$textfile" ;;
    *)
      echo "mdclip: no clipboard backend for platform '$platform'" >&2; exit 1 ;;
  esac
}

paste_hint() {
  case "$platform" in
    macos) echo "Cmd+V" ;;
    *)     echo "Ctrl+V" ;;
  esac
}

# ---------------------------------------------------------------------------
# Arg parse.
# ---------------------------------------------------------------------------
flavor=""
args=()
for a in "$@"; do
  case "$a" in
    -s|--slack)    flavor=slack ;;
    -d|--discord)  flavor=discord ;;
    -t|--telegram) flavor=telegram ;;
    -w|--whatsapp) flavor=whatsapp ;;
    *) args+=("$a") ;;
  esac
done
set -- "${args[@]:-}"

if [ -z "$flavor" ]; then
  need quarto "needed for its bundled pandoc"
else
  need perl "needed for the $flavor conversion"
fi

# Read markdown from a file arg or stdin.
if [ "$#" -ge 1 ] && [ -n "${1:-}" ] && [ "$1" != "-" ]; then
  [ -f "$1" ] || { echo "mdclip: no such file: $1" >&2; exit 1; }
  src="$(cat -- "$1")"
else
  src="$(cat)"
fi

# ---------------------------------------------------------------------------
# Chat flavours: convert Markdown -> the app's plain-text markup, set plain
# text only. One parametric transform; per-app token table selects the markup.
# ---------------------------------------------------------------------------
if [ -n "$flavor" ]; then
  chattext="$(printf '%s' "$src" | FLAVOR="$flavor" perl -CSD -Mstrict -Mwarnings -e '
    my %F = (
      slack    => { bo=>"*",  bc=>"*",  io=>"_",  ic=>"_",  so=>"~",  sc=>"~",  hdr=>"bold", bullet=>"\x{2022} ", link=>"slack" },
      discord  => { bo=>"**", bc=>"**", io=>"*",  ic=>"*",  so=>"~~", sc=>"~~", hdr=>"keep", bullet=>"- ",        link=>"plain" },
      telegram => { bo=>"**", bc=>"**", io=>"__", ic=>"__", so=>"~~", sc=>"~~", hdr=>"bold", bullet=>"\x{2022} ", link=>"keep"  },
      whatsapp => { bo=>"*",  bc=>"*",  io=>"_",  ic=>"_",  so=>"~",  sc=>"~",  hdr=>"bold", bullet=>"- ",        link=>"plain" },
    );
    my $f = $F{$ENV{FLAVOR}} or die "mdclip: unknown flavor: $ENV{FLAVOR}\n";
    my ($bo,$bc,$io,$ic,$so,$sc)=@{$f}{qw(bo bc io ic so sc)};
    my $in_code = 0;
    while (my $line = <STDIN>) {
      chomp $line;
      if ($line =~ /^\s*```/) { $in_code = !$in_code; print "$line\n"; next; }
      if ($in_code)           { print "$line\n"; next; }
      # drop GFM table delimiter rows (pipes + dashes/colons/space only)
      next if ($line =~ /\|/ && $line =~ /-/ && $line =~ /^[\s|:\-]+$/);
      # protect inline code spans from the transforms below
      my @spans;
      $line =~ s/(`[^`]*`)/push @spans, $1; "\x00" . $#spans . "\x00"/ge;
      # strikethrough ~~x~~ -> sentinel (before other tilde handling)
      $line =~ s/~~(.+?)~~/\x04$1\x05/g;
      # ATX heading -> bold sentinel, or keep (# ) for flavours with headers
      if ($line =~ /^\s{0,3}\#{1,6}\s+(.*?)\s*\#*\s*$/) {
        my $h = $1;
        $line = "\x02$h\x03" if $f->{hdr} eq "bold";
      }
      # -,*,+ bullets -> per-flavour bullet (before bold/italic touch the *)
      $line =~ s/^(\s*)[-*+]\s+/$1$f->{bullet}/;
      # masked links per flavour
      if ($f->{link} eq "slack") {
        $line =~ s/\[([^\]]+)\]\(([^)\s]+)(?:\s+"[^"]*")?\)/<$2|$1>/g;
      } elsif ($f->{link} eq "plain") {
        $line =~ s/\[([^\]]+)\]\(([^)\s]+)(?:\s+"[^"]*")?\)/$1 ($2)/g;
      }
      # ***bold+italic*** first (else the ** and * passes split it wrong)
      $line =~ s/\*\*\*(.+?)\*\*\*/\x02\x06$1\x07\x03/g;
      # **bold** / __bold__ -> bold sentinel (so italic pass ignores them)
      $line =~ s/\*\*(.+?)\*\*/\x02$1\x03/g;
      $line =~ s/(?<!\w)__(.+?)__(?!\w)/\x02$1\x03/g;
      # *italic* (GFM allows intraword) / _italic_ (word-boundary only, so
      # some_var_name is left intact)
      $line =~ s/\*(\S(?:.*?\S)?)\*/\x06$1\x07/g;
      $line =~ s/(?<!\w)_(\S(?:.*?\S)?)_(?!\w)/\x06$1\x07/g;
      # emit per-flavour tokens
      $line =~ s/\x02/$bo/g; $line =~ s/\x03/$bc/g;
      $line =~ s/\x06/$io/g; $line =~ s/\x07/$ic/g;
      $line =~ s/\x04/$so/g; $line =~ s/\x05/$sc/g;
      # restore code spans
      $line =~ s/\x00(\d+)\x00/$spans[$1]/g;
      print "$line\n";
    }
  ')"

  tmptxt="$(mktemp --suffix=.txt)"
  trap 'rm -f "$tmptxt"' EXIT
  printf '%s' "$chattext" > "$tmptxt"
  set_clip_plain "$tmptxt"
  echo "$flavor markup is on the clipboard (plain text). Paste with $(paste_hint)." >&2
  exit 0
fi

# ---------------------------------------------------------------------------
# Default mode: render GFM -> HTML fragment, set rich clipboard + plain fallback.
# ---------------------------------------------------------------------------
html="$(printf '%s' "$src" | quarto pandoc -f gfm -t html --wrap=none)"

# Give code blocks a light monospace box so they read as code in Gmail
# (pandoc's highlight classes carry no inline styles once out of a stylesheet).
html="${html//<pre /<pre style=\"background:#f6f8fa;padding:10px;border-radius:6px;overflow:auto;font-family:Consolas,Menlo,monospace;font-size:90%\" }"
html="${html//<pre>/<pre style=\"background:#f6f8fa;padding:10px;border-radius:6px;overflow:auto;font-family:Consolas,Menlo,monospace;font-size:90%\">}"

# Tighten paragraph spacing. Two things stack into an oversized gap in Gmail:
#   1. bare <p> carries ~1em top AND bottom margin -> collapse to bottom-only.
#   2. pandoc emits each block on its own line, and this clipboard path renders
#      a bare newline BETWEEN blocks as an extra <br> (same root cause as the
#      --wrap=none fix) -> strip inter-block newlines so only the margin spaces.
html="${html//<p>/<p style=\"margin:0 0 10px 0\">}"
if [[ "$html" != *"<pre"* ]]; then
  # No preformatted code: newlines are pure formatting, safe to drop wholesale.
  html="${html//$'\n'/}"
else
  # Preserve newlines inside <pre> (significant); only collapse after closing
  # block tags, which never appear inside a code block.
  for _ct in '</p>' '</li>' '</ul>' '</ol>' '</h1>' '</h2>' '</h3>' '</h4>' '</h5>' '</h6>' '</blockquote>' '</tr>' '</table>'; do
    html="${html//$_ct$'\n'/$_ct}"
  done
fi

tmphtml="$(mktemp --suffix=.html)"
tmptxt="$(mktemp --suffix=.txt)"
trap 'rm -f "$tmphtml" "$tmptxt"' EXIT
printf '%s' "$html" > "$tmphtml"
printf '%s' "$src"  > "$tmptxt"

set_clip_rich "$tmphtml" "$tmptxt"
echo "Rendered rich text + fallback are on the clipboard. Paste into Gmail with $(paste_hint)." >&2

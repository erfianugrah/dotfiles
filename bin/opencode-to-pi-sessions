#!/usr/bin/env bun
/**
 * opencode-to-pi-sessions — migrate opencode SQLite sessions to Pi JSONL.
 *
 * Reads opencode's session/message/part tables and emits Pi-compatible
 * session files under ~/.pi/agent/sessions/<encoded-cwd>/<timestamp>_<uuid>.jsonl
 * so they appear in `pi -r` and can be browsed via /tree.
 *
 * Lossy where opencode has concepts Pi doesn't (step-start, step-finish,
 * summary, snapshots). Tool calls are split into an assistant message
 * containing the toolCall + a separate toolResult message, matching Pi's
 * session-format.md spec.
 *
 * Usage:
 *   opencode-to-pi-sessions                      # migrate from opencode-dev.db
 *   opencode-to-pi-sessions --db prod            # migrate from opencode.db
 *   opencode-to-pi-sessions --db <full-path>     # migrate from arbitrary DB
 *   opencode-to-pi-sessions --dry-run            # show what would migrate
 *   opencode-to-pi-sessions --limit 50           # only first 50 sessions
 *   opencode-to-pi-sessions --since 2026-05-01   # only sessions newer than date
 *   opencode-to-pi-sessions --min-messages 2     # skip sessions with < N messages (default 2)
 *   opencode-to-pi-sessions --out <dir>          # output dir (default ~/.pi/agent/sessions)
 *   opencode-to-pi-sessions --verbose            # one line per session migrated
 *
 * Idempotent: existing Pi session files are NOT overwritten — re-running
 * skips them. To force re-migration, delete the existing JSONL files first.
 */

import { Database } from "bun:sqlite";
import { existsSync, mkdirSync, readdirSync, writeFileSync } from "fs";
import { homedir } from "os";
import { join } from "path";
import { createHash, randomBytes } from "crypto";

/**
 * Derive a stable v5-style UUID from the opencode session id so re-running
 * the migration produces the SAME filename and the existsSync() idempotency
 * check actually triggers. The previous version used randomUUID() per run
 * which made the dedup check a no-op and bloated ~/.pi/agent/sessions by 5x
 * after a few re-runs.
 */
function deterministicUuid(opencodeId: string): string {
  const h = createHash("sha1").update(`opencode-to-pi:${opencodeId}`).digest("hex");
  // RFC 4122-ish layout: set version nibble to 5, variant nibble to 8/9/a/b.
  const v = "5" + h.slice(13, 16);
  const variantNibble = ((parseInt(h[16], 16) & 0x3) | 0x8).toString(16);
  const r = variantNibble + h.slice(17, 20);
  return `${h.slice(0, 8)}-${h.slice(8, 12)}-${v}-${r}-${h.slice(20, 32)}`;
}

// ── arg parsing (no deps) ─────────────────────────────────────────────────

const argv = process.argv.slice(2);
function arg(name: string, def?: string): string | undefined {
  const idx = argv.indexOf(name);
  if (idx === -1) return def;
  return argv[idx + 1];
}
function flag(name: string): boolean {
  return argv.includes(name);
}

if (flag("--help") || flag("-h")) {
  console.log(`Usage: opencode-to-pi-sessions [opts]

  --db <dev|prod|path>   opencode DB to read (default: dev = ~/.local/share/opencode/opencode-dev.db)
                         prod = ~/.local/share/opencode/opencode.db
  --out <dir>            output dir (default: ~/.pi/agent/sessions)
  --dry-run              don't write, just show counts + paths
  --limit <N>            only first N sessions
  --since <YYYY-MM-DD>   skip sessions older than this date
  --min-messages <N>     skip sessions with < N user/assistant messages (default 2)
  --verbose              one line per migrated session
  -h, --help             this help`);
  process.exit(0);
}

const DB_INPUT = arg("--db", "dev")!;
const DB_PATH =
  DB_INPUT === "dev"
    ? join(homedir(), ".local/share/opencode/opencode-dev.db")
    : DB_INPUT === "prod"
      ? join(homedir(), ".local/share/opencode/opencode.db")
      : DB_INPUT;

const OUT_DIR = arg("--out", join(homedir(), ".pi/agent/sessions"))!;
const DRY_RUN = flag("--dry-run");
const VERBOSE = flag("--verbose");
const LIMIT = parseInt(arg("--limit", "0")!, 10);
const SINCE_DATE = arg("--since");
const SINCE_MS = SINCE_DATE ? Date.parse(SINCE_DATE) : 0;
const MIN_MESSAGES = parseInt(arg("--min-messages", "2")!, 10);

// ── helpers ───────────────────────────────────────────────────────────────

function piId(): string {
  return randomBytes(4).toString("hex");
}

function isoFromMs(ms: number): string {
  return new Date(ms).toISOString();
}

function encodeCwd(cwd: string): string {
  const stripped = cwd.replace(/^\//, "");
  return `--${stripped.replace(/\//g, "-")}--`;
}

function timestampForFilename(ms: number): string {
  // 2026-05-20T22-19-40-639Z format (matches Pi's existing filenames)
  return new Date(ms).toISOString().replace(/[:.]/g, "-");
}

// ── conversion ────────────────────────────────────────────────────────────

type PartData =
  | { type: "text"; text: string }
  | {
      type: "tool";
      tool: string;
      callID: string;
      state: {
        status: "completed" | "error" | "running";
        input?: Record<string, unknown>;
        output?: unknown;
        error?: string;
        metadata?: unknown;
      };
    }
  | { type: "file"; mime: string; url: string; filename?: string }
  | { type: "step-start" | "step-finish"; [k: string]: unknown };

type MessageData = {
  role: "user" | "assistant";
  agent?: string;
  model?: { providerID?: string; modelID?: string } | null;
};

function placeholderUsage() {
  return {
    input: 0,
    output: 0,
    cacheRead: 0,
    cacheWrite: 0,
    totalTokens: 0,
    cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0, total: 0 },
  };
}

function convertSession(db: Database, sessionRow: { id: string; directory: string; title: string; time_created: number }) {
  const messages = db
    .query<{ id: string; time_created: number; data: string }, [string]>(
      "SELECT id, time_created, data FROM message WHERE session_id = ? ORDER BY time_created ASC",
    )
    .all(sessionRow.id);

  if (messages.length < MIN_MESSAGES) return null;

  const lines: string[] = [];
  const sessionUuid = deterministicUuid(sessionRow.id);

  // SessionHeader
  lines.push(
    JSON.stringify({
      type: "session",
      version: 3,
      id: sessionUuid,
      timestamp: isoFromMs(sessionRow.time_created),
      cwd: sessionRow.directory,
    }),
  );

  let lastEntryId: string | null = null;
  let realMessageCount = 0;

  for (const msg of messages) {
    let msgData: MessageData;
    try {
      msgData = JSON.parse(msg.data);
    } catch {
      continue;
    }

    const role = msgData.role;
    if (role !== "user" && role !== "assistant") continue;

    const parts = db
      .query<{ data: string; time_created: number }, [string]>(
        "SELECT data, time_created FROM part WHERE message_id = ? ORDER BY time_created ASC",
      )
      .all(msg.id);

    const content: Array<Record<string, unknown>> = [];
    const toolResults: Array<{ message: Record<string, unknown>; ts: number }> = [];

    for (const partRow of parts) {
      let part: PartData;
      try {
        part = JSON.parse(partRow.data);
      } catch {
        continue;
      }

      if (part.type === "text") {
        if (part.text?.trim()) content.push({ type: "text", text: part.text });
      } else if (part.type === "file") {
        // Only image files map to Pi's ImageContent; skip text/PDF for now.
        if (!part.mime?.startsWith("image/")) continue;
        const m = part.url?.match(/^data:([^;]+);base64,(.+)$/);
        if (!m) continue;
        content.push({ type: "image", data: m[2], mimeType: m[1] });
      } else if (part.type === "tool" && role === "assistant") {
        content.push({
          type: "toolCall",
          id: part.callID,
          name: part.tool,
          arguments: part.state?.input ?? {},
        });
        if (part.state?.status === "completed") {
          toolResults.push({
            ts: partRow.time_created,
            message: {
              role: "toolResult",
              toolCallId: part.callID,
              toolName: part.tool,
              content: [
                {
                  type: "text",
                  text:
                    typeof part.state.output === "string"
                      ? part.state.output
                      : JSON.stringify(part.state.output ?? null),
                },
              ],
              details: part.state.metadata,
              isError: false,
              timestamp: partRow.time_created,
            },
          });
        } else if (part.state?.status === "error") {
          toolResults.push({
            ts: partRow.time_created,
            message: {
              role: "toolResult",
              toolCallId: part.callID,
              toolName: part.tool,
              content: [{ type: "text", text: part.state.error ?? "Tool error" }],
              isError: true,
              timestamp: partRow.time_created,
            },
          });
        }
      }
      // step-start, step-finish → skipped (opencode internals; no Pi equivalent)
    }

    if (content.length === 0 && toolResults.length === 0) continue;

    // Emit message entry (if there's content)
    if (content.length > 0) {
      const id = piId();
      const messageBody: Record<string, unknown> = {
        role,
        content,
        timestamp: msg.time_created,
      };
      if (role === "assistant") {
        messageBody.api = msgData.model?.providerID ?? "unknown";
        messageBody.provider = msgData.model?.providerID ?? "unknown";
        messageBody.model = msgData.model?.modelID ?? "unknown";
        messageBody.usage = placeholderUsage();
        messageBody.stopReason = "stop";
      }
      lines.push(
        JSON.stringify({
          type: "message",
          id,
          parentId: lastEntryId,
          timestamp: isoFromMs(msg.time_created),
          message: messageBody,
        }),
      );
      lastEntryId = id;
      realMessageCount++;
    }

    // Emit tool result entries
    for (const tr of toolResults) {
      const id = piId();
      lines.push(
        JSON.stringify({
          type: "message",
          id,
          parentId: lastEntryId,
          timestamp: isoFromMs(tr.ts),
          message: tr.message,
        }),
      );
      lastEntryId = id;
    }
  }

  if (realMessageCount < MIN_MESSAGES) return null;

  return { lines, sessionUuid };
}

// ── main ──────────────────────────────────────────────────────────────────

if (!existsSync(DB_PATH)) {
  console.error(`✗ DB not found: ${DB_PATH}`);
  process.exit(1);
}

console.log(`reading: ${DB_PATH}`);
console.log(`writing: ${OUT_DIR}${DRY_RUN ? " (dry-run)" : ""}`);

const db = new Database(DB_PATH, { readonly: true });
const sessionRows = db
  .query<{ id: string; directory: string; title: string; time_created: number }, []>(
    "SELECT id, directory, title, time_created FROM session ORDER BY time_created ASC",
  )
  .all();

console.log(`found ${sessionRows.length} sessions`);

let migrated = 0;
let skippedEmpty = 0;
let skippedOld = 0;
let skippedExists = 0;
let failed = 0;
const startedAt = Date.now();

for (const sessionRow of sessionRows) {
  if (SINCE_MS > 0 && sessionRow.time_created < SINCE_MS) {
    skippedOld++;
    continue;
  }

  let result: ReturnType<typeof convertSession>;
  try {
    result = convertSession(db, sessionRow);
  } catch (err) {
    failed++;
    console.error(`✗ ${sessionRow.id}: ${(err as Error).message}`);
    continue;
  }
  if (!result) {
    skippedEmpty++;
    continue;
  }

  const subDir = join(OUT_DIR, encodeCwd(sessionRow.directory));
  const filename = `${timestampForFilename(sessionRow.time_created)}_${result.sessionUuid}.jsonl`;
  const outPath = join(subDir, filename);

  // Idempotency check — skip if ANY file in the cwd dir starts with this
  // timestamp prefix. Two reasons we don't just check `outPath`:
  //   1. Older versions of this script generated random UUIDs per run, so
  //      legacy files have different UUIDs from what we'd write now.
  //   2. Even with the new deterministic UUID derived from sessionRow.id,
  //      the timestamp prefix alone is millisecond-precise and unique per
  //      opencode session, so a prefix match is sufficient and avoids
  //      re-migration churn.
  // Force re-migration by deleting the matching JSONL file(s).
  const timestampPrefix = `${timestampForFilename(sessionRow.time_created)}_`;
  const alreadyMigrated =
    existsSync(subDir) &&
    readdirSync(subDir).some(
      (name) => name.startsWith(timestampPrefix) && name.endsWith(".jsonl"),
    );
  if (alreadyMigrated) {
    skippedExists++;
    continue;
  }

  if (DRY_RUN) {
    if (VERBOSE) console.log(`  would write ${outPath} (${result.lines.length} entries)`);
    migrated++;
  } else {
    if (!existsSync(subDir)) mkdirSync(subDir, { recursive: true });
    writeFileSync(outPath, result.lines.join("\n") + "\n");
    if (VERBOSE) console.log(`  ${outPath} (${result.lines.length} entries)`);
    migrated++;
  }

  if (LIMIT > 0 && migrated >= LIMIT) break;
}

const elapsed = ((Date.now() - startedAt) / 1000).toFixed(1);
console.log(``);
console.log(`✓ migrated: ${migrated}`);
console.log(`  skipped (empty/short): ${skippedEmpty}`);
console.log(`  skipped (since-filter): ${skippedOld}`);
console.log(`  skipped (already exists): ${skippedExists}`);
console.log(`  failed: ${failed}`);
console.log(`  elapsed: ${elapsed}s`);

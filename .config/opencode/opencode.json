{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama-server": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma-4-31B-it-Q4_K_M": {
          "name": "Gemma 4 31B Dense (local)"
        },
        "gemma-4-26b-a4b-it-Q4_K_M": {
          "name": "Gemma 4 26B MoE (local)"
        }
      }
    }
  },
  "mcp": {
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "enabled": true,
      "oauth": {}
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "mermaid": {
      "type": "local",
      "command": ["npx", "-y", "@peng-shawn/mermaid-mcp-server"],
      "environment": {
        "CONTENT_IMAGE_SUPPORTED": "false"
      },
      "enabled": false
    },
    "terraform": {
      "type": "local",
      "command": ["npx", "-y", "terraform-mcp-server"],
      "enabled": false
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "shadcn-ui-mcp-server"],
      "enabled": false
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp",
      "enabled": false,
      "oauth": {}
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": false,
      "oauth": {}
    }
  }
}

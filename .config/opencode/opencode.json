{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "enabled": true,
      "oauth": {}
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "mermaid": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@peng-shawn/mermaid-mcp-server"
      ],
      "environment": {
        "CONTENT_IMAGE_SUPPORTED": "false"
      },
      "enabled": false
    },
    "terraform": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "terraform-mcp-server"
      ],
      "enabled": false
    },
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "shadcn-ui-mcp-server"
      ],
      "enabled": false
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp",
      "enabled": false,
      "oauth": {}
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": false,
      "oauth": {}
    },
    "whisper": {
      "type": "local",
      "command": [
        "python3",
        "/home/erfi/llm-compose/mcp/whisper-server.py"
      ],
      "environment": {
        "WHISPER_URL": "http://localhost:7860"
      },
      "timeout": 120000,
      "enabled": true
    },
    "comfyui": {
      "type": "local",
      "command": [
        "python3",
        "/home/erfi/llm-compose/mcp/comfyui-server.py"
      ],
      "environment": {
        "COMFYUI_PROXY_URL": "http://localhost:11434",
        "COMFYUI_OUTPUT_DIR": "/home/erfi/docker-volumes/comfyui/output"
      },
      "timeout": 120000,
      "enabled": true
    },
    "lora-train": {
      "type": "local",
      "command": [
        "python3",
        "/home/erfi/llm-compose/mcp/train-server.py"
      ],
      "environment": {
        "TRAIN_PROXY_URL": "http://localhost:11434",
        "TRAIN_OUTPUT_DIR": "/home/erfi/docker-volumes/training-data/output",
        "LORAS_DIR": "/home/erfi/docker-volumes/comfyui/models/loras"
      },
      "timeout": 120000,
      "enabled": true
    },
    "research": {
      "type": "local",
      "command": [
        "python3",
        "/home/erfi/research/mcp/research-server.py"
      ],
      "environment": {
        "SEARXNG_URL": "https://searxng.erfi.io",
        "CRAWLER_URL": "https://crawler.erfi.io",
        "OSINT_URL":   "https://osint.erfi.io"
      },
      "timeout": 120000,
      "enabled": true
    }
  }
}
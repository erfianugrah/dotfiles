{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "mermaid": {
      "type": "local",
      "command": ["npx", "-y", "@peng-shawn/mermaid-mcp-server"],
      "environment": {
        "CONTENT_IMAGE_SUPPORTED": "false"
      },
      "enabled": true
    },
    "terraform": {
      "type": "local",
      "command": ["npx", "-y", "terraform-mcp-server"],
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "shadcn-ui-mcp-server"],
      "enabled": true
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp",
      "enabled": true,
      "oauth": {}
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": true,
      "oauth": {}
    }
  }
}

[http]
	postBuffer = 524288000
	version = HTTP/2
[init]
	defaultBranch = main
	templateDir = ~/.git-template
[push]
	autoSetupRemote = true
[credential "https://dev.azure.com"]
	useHttpPath = true
[credential]
	credentialStore = cache
	guiPrompt = false
[commit]
	gpgsign = true
[user]
	name = Erfi Anugrah
	email = erfi.anugrah@gmail.com
	signingkey = B9D283E8AE4E56B4
[alias]
	dsf = diff --color
[core]
	pager = delta
	; Global hooks dir (stow-linked to dotfiles/.config/git/hooks). Runs the
	; pre-push confidential/secret backstop in EVERY repo, retroactively. The
	; pre-commit here chains to each repo's own .git/hooks/pre-commit so the
	; templateDir SOPS check is preserved. Unset to revert: git config --global --unset core.hooksPath
	hooksPath = ~/.config/git/hooks
[interactive]
	diffFilter = delta --color-only
[color]
	ui = true
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = 11
	frag = magenta bold
	func = 146 bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
[delta]
	navigate = true
	dark = true
[merge]
	conflictstyle = diff3
[pull]
	rebase = true
[rerere]
	enabled = true
[fetch]
	prune = true

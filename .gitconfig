[http]
	postBuffer = 524288000
	version = HTTP/2
[init]
	defaultBranch = main
	templateDir = /home/erfi/.git-template
[push]
    autoSetupRemote = true
[credential "https://dev.azure.com"]
	useHttpPath = true
[credential]
	credentialStore = cache
  guiPrompt = false
	helper = 
	helper = /usr/local/bin/git-credential-manager
[commit]
	gpgsign = true
[user]
	name = Erfi Anugrah
	email = erfi.anugrah@gmail.com
	signingkey = AEF0D6CDEA5FBB1C
[alias]
	dsf = diff --color
[pager]
	dsf = diff-so-fancy | less --tabs=4 -RFXS
[core]
	pager = diff-so-fancy | less --tabs=4 -RF
[interactive]
	diffFilter = diff-so-fancy --patch
[color]
	ui = true
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = 11
	frag = magenta bold
	func = 146 bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
[diff-so-fancy]
	changeHunkIndicators = false
	stripLeadingSymbols = false
	useUnicodeRuler = false
	markEmptyLines = false
[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection

[merge]
    conflictstyle = zdiff3
; [url "git@github.com:ingka-group-digital"]
; 	insteadOf = https://github.com/ingka-group-digital/
